{
  "name": "rent-agent",
  "version": "1.0.0",
  "description": "Automated maintenance & pest control request agent for RentCafe portals",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "login": "tsx src/login.ts",
    "pest-control": "tsx src/pest-control.ts",
    "submit": "tsx src/submit.ts",
    "gmail-setup": "tsx src/gmail-setup.ts",
    "record": "tsx src/workflow/recorder.ts",
    "replay": "tsx src/workflow/replay-cli.ts",
    "bot": "tsx src/telegram-bot.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@browserbasehq/sdk": "^2.14.1",
    "2captcha-ts": "^2.4.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "googleapis": "^173.0.0",
    "grammy": "^1.44.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.48.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "twilio": "^5.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
