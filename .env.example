# RentCafe portal
RENTCAFE_URL=https://atlanticpalazzoliving.securecafenet.com/residentservices/the-atlantic-palazzo-living/userlogin
RENTCAFE_EMAIL=your-email@example.com

# Browserbase (cloud browser with captcha solving)
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_project_id
BROWSERBASE_CONTEXT_ID=rentcafe-session

# Twilio SMS
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
USER_PHONE_NUMBER=+1234567890

# Server port for Twilio webhook
PORT=3000

# Pest control schedule (cron format — default: every Monday at 9am)
PEST_CONTROL_CRON=0 9 * * 1
