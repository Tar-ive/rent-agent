# RentCafe portal
RENTCAFE_URL=https://your-property.securecafenet.com/residentservices/your-property/userlogin
RENTCAFE_EMAIL=your-email@example.com

# Browserbase (cloud browser with captcha solving)
BROWSERBASE_API_KEY=your_browserbase_api_key
BROWSERBASE_PROJECT_ID=your_project_id
BROWSERBASE_CONTEXT_ID=

# Telegram Bot (preferred messaging channel)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=

# Gmail API (auto-read OTP codes — fully hands-free login)
GMAIL_CLIENT_ID=your_oauth2_client_id
GMAIL_CLIENT_SECRET=your_oauth2_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_OTP_SENDER=noreply

# Twilio SMS (optional fallback if Telegram not configured)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
USER_PHONE_NUMBER=

# Server port (for SMS webhook, not needed for Telegram)
PORT=3000

# Pest control schedule (cron format — default: every Monday at 9am)
PEST_CONTROL_CRON=0 9 * * 1
